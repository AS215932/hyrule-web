{
  "name": "hyrule-web-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Frontend build for hyrule-web (Vite + TypeScript + Tailwind). Bundles to hyrule_web/static/dist/; the committed bundle is shipped by the Ansible deploy (issue #14).",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "stylelint": "stylelint \"frontend/src/**/*.css\"",
    "typecheck": "tsc --noEmit",
    "check": "prettier --check . && eslint . && stylelint \"frontend/src/**/*.css\" && tsc --noEmit && vitest run --coverage && vite build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fullhuman/postcss-purgecss": "^7.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^3.4.19",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@solana/kit": "6.1.0",
    "@solana/wallet-standard-features": "1.3.0",
    "@wallet-standard/app": "1.1.0",
    "@wallet-standard/base": "1.1.0",
    "@wallet-standard/features": "1.1.0",
    "@walletconnect/ethereum-provider": "^2.23.9",
    "@x402/core": "2.18.0",
    "@x402/svm": "2.18.0",
    "ajv": "^8.20.0"
  }
}
